<!DOCTYPE html>
<html>

<head>
<title>Edit Transaction</title>
<link rel="stylesheet" href="/css/style.css">
</head>

<body>

<div class="form-container">

<h2>Edit Transaction</h2>

<form action="/update/<%= transaction.id %>" method="POST">

<select name="type">

<option value="income" <%= transaction.type==="income"?"selected":"" %>>Income</option>

<option value="expense" <%= transaction.type==="expense"?"selected":"" %>>Expense</option>

</select>

<input type="text" name="category" value="<%= transaction.category %>" required>

<input type="number" name="amount" value="<%= transaction.amount %>" required>

<input type="date" name="date" value="<%= transaction.date.toISOString().split('T')[0] %>" required>

<button type="submit">Update</button>

</form>

</div>

</body>

</html>